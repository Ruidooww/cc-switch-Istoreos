#!/bin/sh

CONFIG="ccswitch"
DEFAULT_CLAUDE_DIR="/root/.claude"
DEFAULT_CODEX_DIR="/root/.codex"
DEFAULT_BACKUP_DIR="/etc/ccswitch/backups"
DEFAULT_SECRET_DIR="/etc/ccswitch/secrets"
DEFAULT_RETAIN="10"
DEFAULT_USAGE_RETAIN="2000"
USAGE_LOG="/etc/ccswitch/usage.jsonl"

json_escape() {
	printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

toml_escape() {
	printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

json_bool() {
	[ "$1" = "1" ] && printf 'true' || printf 'false'
}

json_error() {
	printf '{"ok":false,"error":"%s"}\n' "$(json_escape "$1")"
}

json_ok() {
	printf '{"ok":true,"message":"%s"}\n' "$(json_escape "$1")"
}

json_stream_escape() {
	sed 's/\\/\\\\/g; s/"/\\"/g; s/$/\\n/' | tr -d '\n'
}

json_file_excerpt() {
	local file="$1" limit="${2:-1200}"
	[ -f "$file" ] || return 0
	head -c "$limit" "$file" 2>/dev/null | tr '\r\n' '  ' | sed 's/\\/\\\\/g; s/"/\\"/g'
}

json_arg() {
	jsonfilter -s "$1" -e "$2" 2>/dev/null
}

global_get() {
	local key="$1" default="$2" value
	value="$(uci -q get "$CONFIG.global.$key")"
	[ -n "$value" ] && printf '%s' "$value" || printf '%s' "$default"
}

section_get() {
	local section="$1" key="$2"
	uci -q get "$CONFIG.$section.$key"
}

validate_section() {
	local section="$1" expected="$2" actual
	case "$section" in
		''|*[!A-Za-z0-9_]*)
			json_error "Invalid provider section"
			return 1
		;;
	esac

	actual="$(uci -q get "$CONFIG.$section")"
	if [ "$actual" != "$expected" ]; then
		json_error "Provider section type mismatch"
		return 1
	fi
	return 0
}

require_value() {
	local value="$1" label="$2"
	if [ -z "$value" ]; then
		json_error "$label is required"
		return 1
	fi
	return 0
}

valid_url() {
	case "$1" in
		http://*|https://*) return 0 ;;
		*) return 1 ;;
	esac
}

timestamp() {
	date '+%Y%m%d-%H%M%S'
}

backup_dir() {
	global_get backup_dir "$DEFAULT_BACKUP_DIR"
}

backup_retain() {
	global_get backup_retain "$DEFAULT_RETAIN"
}

cleanup_backups() {
	local dir="$1" retain="$2" item count
	[ -d "$dir" ] || return 0
	[ "$retain" -gt 0 ] 2>/dev/null || retain="$DEFAULT_RETAIN"

	count=0
	for item in $(ls -1t "$dir" 2>/dev/null); do
		count=$((count + 1))
		[ "$count" -le "$retain" ] && continue
		rm -f "$dir/$item"
	done
}

backup_file() {
	local app="$1" path="$2" dir base stamp retain
	[ -f "$path" ] || return 0

	dir="$(backup_dir)/$app"
	base="$(basename "$path")"
	stamp="$(timestamp)"
	retain="$(backup_retain)"

	mkdir -p "$dir" || return 1
	cp "$path" "$dir/$base.$stamp" || return 1
	cleanup_backups "$dir" "$retain"
}

write_atomic() {
	local path="$1" tmp
	tmp="$path.tmp.$$"
	mkdir -p "$(dirname "$path")" || return 1
	umask 077
	cat > "$tmp" || return 1
	mv "$tmp" "$path" || {
		rm -f "$tmp"
		return 1
	}
	chmod 600 "$path" 2>/dev/null
}

secret_path() {
	local section="$1"
	printf '%s/%s.key' "$DEFAULT_SECRET_DIR" "$section"
}

secret_get() {
	local section="$1" ref key
	ref="$(section_get "$section" api_key_ref)"
	if [ -n "$ref" ] && [ -f "$ref" ]; then
		sed -n '1p' "$ref"
		return 0
	fi
	key="$(section_get "$section" api_key)"
	printf '%s' "$key"
}

secret_store_if_needed() {
	local section="$1" key="$2" path
	[ -n "$key" ] || return 0
	[ "$key" = "********" ] && return 0
	path="$(secret_path "$section")"
	mkdir -p "$DEFAULT_SECRET_DIR" || return 1
	chmod 700 "$DEFAULT_SECRET_DIR" 2>/dev/null
	umask 077
	printf '%s' "$key" > "$path" || return 1
	chmod 600 "$path" 2>/dev/null
	uci -q set "$CONFIG.$section.api_key_ref=$path"
	uci -q delete "$CONFIG.$section.api_key"
}

has_secret() {
	local section="$1" ref
	ref="$(section_get "$section" api_key_ref)"
	[ -n "$ref" ] && [ -f "$ref" ] && return 0
	[ -n "$(section_get "$section" api_key)" ] && return 0
	return 1
}

normalize_codex_base_url() {
	local url
	url="${1%/}"
	case "$url" in
		*/v1) printf '%s' "$url" ;;
		http://*/*|https://*/*) printf '%s' "$url" ;;
		*) printf '%s/v1' "$url" ;;
	esac
}

join_url() {
	local base="$1" path="$2" full="$3"
	base="${base%/}"
	path="/${path#/}"

	if [ "$full" = "1" ]; then
		case "$path" in
			/v1/messages|/v1/chat/completions|/v1/responses)
				printf '%s' "$base"
				return 0
			;;
		esac
	fi

	printf '%s%s' "$base" "$path"
}

mask_key() {
	local key="$1"
	[ -n "$key" ] || { printf ''; return 0; }
	printf '%s' "$key" | sed 's/^\(....\).*$/\1********/'
}

proxy_cli_base_url() {
	local address port
	address="$(uci -q get "$CONFIG.proxy.listen_address")"
	port="$(uci -q get "$CONFIG.proxy.listen_port")"
	[ -n "$address" ] || address="127.0.0.1"
	[ -n "$port" ] || port="15721"
	case "$address" in
		0.0.0.0|::|localhost) address="127.0.0.1" ;;
	esac
	printf 'http://%s:%s' "$address" "$port"
}

ensure_proxy_running() {
	uci -q set "$CONFIG.proxy.enabled=1"
	uci -q commit "$CONFIG"
	if [ -x /etc/init.d/ccswitch-proxy ]; then
		/etc/init.d/ccswitch-proxy enable >/dev/null 2>&1
		/etc/init.d/ccswitch-proxy restart >/dev/null 2>&1
	fi
}

provider_type_for_app() {
	case "$1" in
		claude) printf 'claude_provider' ;;
		codex) printf 'codex_provider' ;;
	esac
}

extract_status() {
	awk '/^HTTP\// { code=$2 } END { if (code) print code; else print 502 }' "$1" 2>/dev/null
}

diagnosis_type() {
	local status="$1" body="$2"
	if grep -q '"type"[[:space:]]*:[[:space:]]*"network_error"' "$body" 2>/dev/null; then
		printf 'network_error'
		return 0
	fi

	case "$status" in
		2*|3*) printf 'ok' ;;
		400)
			if grep -qi 'model' "$body" 2>/dev/null; then
				printf 'model_or_request_error'
			else
				printf 'bad_request'
			fi
		;;
		401|403) printf 'auth_error' ;;
		404)
			if grep -qi 'model' "$body" 2>/dev/null; then
				printf 'model_not_found'
			else
				printf 'path_not_found'
			fi
		;;
		408|504) printf 'timeout' ;;
		429) printf 'rate_limited' ;;
		5*) printf 'upstream_error' ;;
		*) printf 'request_failed' ;;
	esac
}

diagnosis_hint() {
	local kind="$1"
	case "$kind" in
		ok) printf '连接成功' ;;
		auth_error) printf '上游认证失败，请检查 API Key 或认证字段' ;;
		rate_limited) printf '上游限流或额度不足' ;;
		model_not_found) printf '模型不存在，或当前账号没有该模型权限' ;;
		model_or_request_error) printf '请求参数或模型名称可能不兼容' ;;
		path_not_found) printf '接口路径不存在，请检查 Base URL 和完整 URL 设置' ;;
		timeout) printf '上游响应超时，请检查网络或调大超时时间' ;;
		upstream_error) printf '上游服务返回 5xx 错误' ;;
		network_error) printf '本机无法连接上游，可能是 DNS、网络、TLS 或反代不可达' ;;
		bad_request) printf '上游认为请求格式有误' ;;
		*) printf '请求失败，请查看响应内容或系统日志' ;;
	esac
}

apply_claude() {
	local section="$1" name base_url live_base api_key new_api_key api_format api_key_field model haiku_model sonnet_model opus_model hide_ai_signature teammates_mode enable_tool_search max_thinking_enabled disable_auto_update dir path route_mode live_key

	validate_section "$section" "claude_provider" || return 0

	name="$(section_get "$section" name)"
	base_url="$(section_get "$section" base_url)"
	new_api_key="$(section_get "$section" api_key)"
	secret_store_if_needed "$section" "$new_api_key" || {
		json_error "Failed to save API key secret"
		return 0
	}
	api_key="$(secret_get "$section")"
	api_format="$(section_get "$section" api_format)"
	api_key_field="$(section_get "$section" api_key_field)"
	model="$(section_get "$section" model)"
	haiku_model="$(section_get "$section" haiku_model)"
	sonnet_model="$(section_get "$section" sonnet_model)"
	opus_model="$(section_get "$section" opus_model)"
	hide_ai_signature="$(section_get "$section" hide_ai_signature)"
	teammates_mode="$(section_get "$section" teammates_mode)"
	enable_tool_search="$(section_get "$section" enable_tool_search)"
	max_thinking_enabled="$(section_get "$section" max_thinking_enabled)"
	disable_auto_update="$(section_get "$section" disable_auto_update)"
	route_mode="$(global_get claude_route_mode direct)"
	[ -n "$api_format" ] || api_format="anthropic"
	[ -n "$api_key_field" ] || api_key_field="ANTHROPIC_AUTH_TOKEN"
	[ -n "$haiku_model" ] || haiku_model="$model"
	[ -n "$sonnet_model" ] || sonnet_model="$model"
	[ -n "$opus_model" ] || opus_model="$model"

	require_value "$name" "Name" || return 0
	require_value "$base_url" "Base URL" || return 0
	require_value "$api_key" "API Key" || return 0
	require_value "$model" "Model" || return 0

	valid_url "$base_url" || {
		json_error "Base URL must start with http:// or https://"
		return 0
	}

	case "$api_key_field" in
		ANTHROPIC_AUTH_TOKEN|ANTHROPIC_API_KEY) ;;
		*) json_error "Unsupported Claude API key field"; return 0 ;;
	esac

	case "$api_format" in
		anthropic) ;;
		openai_chat|openai_responses)
			json_error "Claude routing currently requires an Anthropic-compatible provider endpoint"
			return 0
		;;
		*) json_error "Unsupported Claude API format"; return 0 ;;
	esac

	live_base="$base_url"
	live_key="$api_key"
	if [ "$route_mode" = "proxy" ]; then
		live_base="$(proxy_cli_base_url)"
		live_key="ccswitch-proxy"
	fi

	dir="$(global_get claude_config_dir "$DEFAULT_CLAUDE_DIR")"
	path="$dir/settings.json"
	backup_file claude "$path" || {
		json_error "Failed to create Claude backup"
		return 0
	}

	{
		printf '{\n'
		printf '  "env": {\n'
		printf '    "ANTHROPIC_BASE_URL": "%s",\n' "$(json_escape "$live_base")"
		printf '    "%s": "%s",\n' "$api_key_field" "$(json_escape "$live_key")"
		printf '    "ANTHROPIC_MODEL": "%s",\n' "$(json_escape "$model")"
		printf '    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "%s",\n' "$(json_escape "$haiku_model")"
		printf '    "ANTHROPIC_DEFAULT_SONNET_MODEL": "%s",\n' "$(json_escape "$sonnet_model")"
		printf '    "ANTHROPIC_DEFAULT_OPUS_MODEL": "%s"' "$(json_escape "$opus_model")"
		[ "$max_thinking_enabled" = "1" ] && printf ',\n    "MAX_THINKING_TOKENS": "32000"'
		printf '\n'
		printf '  }'
		[ "$hide_ai_signature" = "1" ] && printf ',\n  "includeCoAuthoredBy": false'
		[ "$teammates_mode" = "1" ] && printf ',\n  "forceLoginMethod": "console"'
		[ "$enable_tool_search" = "1" ] && printf ',\n  "enableToolSearch": true'
		[ "$disable_auto_update" = "1" ] && printf ',\n  "disableAutoUpdate": true'
		printf '\n'
		printf '}\n'
	} | write_atomic "$path" || {
		json_error "Failed to write Claude settings.json"
		return 0
	}

	uci -q set "$CONFIG.global.current_claude=$section"
	uci -q set "$CONFIG.$section.enabled=1"
	uci -q delete "$CONFIG.$section.api_key"
	uci -q commit "$CONFIG"
	[ "$route_mode" = "proxy" ] && ensure_proxy_running
	logger -t ccswitch "Claude provider '$name' applied to $path route_mode=$route_mode"
	json_ok "Claude provider applied"
}

apply_codex() {
	local section="$1" name base_url api_key new_api_key model wire_api dir auth_path config_path codex_base_url route_mode live_key

	validate_section "$section" "codex_provider" || return 0

	name="$(section_get "$section" name)"
	base_url="$(section_get "$section" base_url)"
	new_api_key="$(section_get "$section" api_key)"
	secret_store_if_needed "$section" "$new_api_key" || {
		json_error "Failed to save API key secret"
		return 0
	}
	api_key="$(secret_get "$section")"
	model="$(section_get "$section" model)"
	wire_api="$(section_get "$section" wire_api)"
	route_mode="$(global_get codex_route_mode direct)"
	[ -n "$wire_api" ] || wire_api="responses"

	require_value "$name" "Name" || return 0
	require_value "$base_url" "Base URL" || return 0
	require_value "$api_key" "API Key" || return 0
	require_value "$model" "Model" || return 0

	valid_url "$base_url" || {
		json_error "Base URL must start with http:// or https://"
		return 0
	}

	case "$wire_api" in
		responses|chat) ;;
		*) json_error "Unsupported Codex wire API"; return 0 ;;
	esac

	codex_base_url="$(normalize_codex_base_url "$base_url")"
	live_key="$api_key"
	if [ "$route_mode" = "proxy" ]; then
		codex_base_url="$(normalize_codex_base_url "$(proxy_cli_base_url)")"
		live_key="ccswitch-proxy"
	fi

	dir="$(global_get codex_config_dir "$DEFAULT_CODEX_DIR")"
	auth_path="$dir/auth.json"
	config_path="$dir/config.toml"
	backup_file codex "$auth_path" || {
		json_error "Failed to create Codex auth backup"
		return 0
	}
	backup_file codex "$config_path" || {
		json_error "Failed to create Codex config backup"
		return 0
	}

	{
		printf '{\n'
		printf '  "OPENAI_API_KEY": "%s"\n' "$(json_escape "$live_key")"
		printf '}\n'
	} | write_atomic "$auth_path" || {
		json_error "Failed to write Codex auth.json"
		return 0
	}

	{
		printf 'model_provider = "ccswitch"\n'
		printf 'model = "%s"\n\n' "$(toml_escape "$model")"
		printf '[model_providers.ccswitch]\n'
		printf 'name = "CC Switch"\n'
		printf 'base_url = "%s"\n' "$(toml_escape "$codex_base_url")"
		printf 'wire_api = "%s"\n' "$(toml_escape "$wire_api")"
		printf 'requires_openai_auth = true\n'
	} | write_atomic "$config_path" || {
		json_error "Failed to write Codex config.toml"
		return 0
	}

	uci -q set "$CONFIG.global.current_codex=$section"
	uci -q set "$CONFIG.$section.enabled=1"
	uci -q delete "$CONFIG.$section.api_key"
	uci -q commit "$CONFIG"
	[ "$route_mode" = "proxy" ] && ensure_proxy_running
	logger -t ccswitch "Codex provider '$name' applied to $dir route_mode=$route_mode"
	json_ok "Codex provider applied"
}

preview_provider() {
	local app="$1" section="$2" type name base_url api_key model route_mode live_base live_key api_key_field api_format wire_api is_full_url haiku_model sonnet_model opus_model

	type="$(provider_type_for_app "$app")"
	[ -n "$type" ] || { json_error "Unsupported app"; return 0; }
	validate_section "$section" "$type" || return 0

	name="$(section_get "$section" name)"
	base_url="$(section_get "$section" base_url)"
	api_key="$(section_get "$section" api_key)"
	if [ -n "$api_key" ] && [ "$api_key" != "********" ]; then
		secret_store_if_needed "$section" "$api_key" >/dev/null 2>&1
		uci -q commit "$CONFIG"
	fi
	api_key="$(secret_get "$section")"
	model="$(section_get "$section" model)"

	case "$app" in
		claude)
			route_mode="$(global_get claude_route_mode direct)"
			api_key_field="$(section_get "$section" api_key_field)"
			api_format="$(section_get "$section" api_format)"
			is_full_url="$(section_get "$section" is_full_url)"
			haiku_model="$(section_get "$section" haiku_model)"
			sonnet_model="$(section_get "$section" sonnet_model)"
			opus_model="$(section_get "$section" opus_model)"
			[ -n "$api_key_field" ] || api_key_field="ANTHROPIC_AUTH_TOKEN"
			[ -n "$api_format" ] || api_format="anthropic"
			[ -n "$haiku_model" ] || haiku_model="$model"
			[ -n "$sonnet_model" ] || sonnet_model="$model"
			[ -n "$opus_model" ] || opus_model="$model"
			live_base="$base_url"
			live_key="$(mask_key "$api_key")"
			if [ "$route_mode" = "proxy" ]; then
				live_base="$(proxy_cli_base_url)"
				live_key="ccswitch-proxy"
			fi
			printf '{"ok":true,"app":"claude","section":"%s","name":"%s","content":"' "$(json_escape "$section")" "$(json_escape "$name")"
			{
				printf '目标文件: %s/settings.json\n' "$(global_get claude_config_dir "$DEFAULT_CLAUDE_DIR")"
				printf '请求模式: %s\n\n' "$route_mode"
				printf '{\n'
				printf '  "env": {\n'
				printf '    "ANTHROPIC_BASE_URL": "%s",\n' "$(json_escape "$live_base")"
				printf '    "%s": "%s",\n' "$api_key_field" "$(json_escape "$live_key")"
				printf '    "ANTHROPIC_MODEL": "%s",\n' "$(json_escape "$model")"
				printf '    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "%s",\n' "$(json_escape "$haiku_model")"
				printf '    "ANTHROPIC_DEFAULT_SONNET_MODEL": "%s",\n' "$(json_escape "$sonnet_model")"
				printf '    "ANTHROPIC_DEFAULT_OPUS_MODEL": "%s"\n' "$(json_escape "$opus_model")"
				printf '  }\n'
				printf '}\n'
			} | json_stream_escape
			printf '"}\n'
		;;
		codex)
			route_mode="$(global_get codex_route_mode direct)"
			wire_api="$(section_get "$section" wire_api)"
			[ -n "$wire_api" ] || wire_api="responses"
			live_base="$(normalize_codex_base_url "$base_url")"
			live_key="$(mask_key "$api_key")"
			if [ "$route_mode" = "proxy" ]; then
				live_base="$(normalize_codex_base_url "$(proxy_cli_base_url)")"
				live_key="ccswitch-proxy"
			fi
			printf '{"ok":true,"app":"codex","section":"%s","name":"%s","content":"' "$(json_escape "$section")" "$(json_escape "$name")"
			{
				printf '目标目录: %s\n' "$(global_get codex_config_dir "$DEFAULT_CODEX_DIR")"
				printf '请求模式: %s\n\n' "$route_mode"
				printf 'auth.json:\n'
				printf '{\n  "OPENAI_API_KEY": "%s"\n}\n\n' "$(json_escape "$live_key")"
				printf 'config.toml:\n'
				printf 'model_provider = "ccswitch"\n'
				printf 'model = "%s"\n\n' "$(toml_escape "$model")"
				printf '[model_providers.ccswitch]\n'
				printf 'name = "CC Switch"\n'
				printf 'base_url = "%s"\n' "$(toml_escape "$live_base")"
				printf 'wire_api = "%s"\n' "$(toml_escape "$wire_api")"
				printf 'requires_openai_auth = true\n'
			} | json_stream_escape
			printf '"}\n'
		;;
	esac
}

clone_provider() {
	local app="$1" section="$2" type new name opt value opts
	type="$(provider_type_for_app "$app")"
	[ -n "$type" ] || { json_error "Unsupported app"; return 0; }
	validate_section "$section" "$type" || return 0

	new="$(uci -q add "$CONFIG" "$type")" || { json_error "Failed to create provider clone"; return 0; }
	case "$app" in
		claude)
			opts="preset website_url base_url is_full_url api_key_ref api_format api_key_field model haiku_model sonnet_model opus_model hide_ai_signature teammates_mode enable_tool_search max_thinking_enabled disable_auto_update input_price_million output_price_million fallback_provider notes"
		;;
		codex)
			opts="preset base_url api_key_ref model wire_api input_price_million output_price_million fallback_provider notes"
		;;
	esac

	name="$(section_get "$section" name)"
	[ -n "$name" ] || name="$section"
	uci -q set "$CONFIG.$new.name=$name 副本"
	uci -q set "$CONFIG.$new.enabled=0"
	for opt in $opts; do
		value="$(section_get "$section" "$opt")"
		[ -n "$value" ] && uci -q set "$CONFIG.$new.$opt=$value"
	done
	uci -q commit "$CONFIG"
	printf '{"ok":true,"section":"%s","message":"Provider cloned"}\n' "$(json_escape "$new")"
}

failover_provider() {
	local app="$1" section="$2" fallback type
	type="$(provider_type_for_app "$app")"
	[ -n "$type" ] || { json_error "Unsupported app"; return 0; }
	validate_section "$section" "$type" || return 0

	fallback="$(section_get "$section" fallback_provider)"
	[ -n "$fallback" ] || { json_error "No fallback provider configured"; return 0; }
	validate_section "$fallback" "$type" || return 0

	case "$app" in
		claude) apply_claude "$fallback" ;;
		codex) apply_codex "$fallback" ;;
	esac
}

test_provider() {
	local app="$1" section="$2" type name base_url api_key new_api_key model api_key_field api_format wire_api is_full_url timeout path url headers body request status kind hint rc

	type="$(provider_type_for_app "$app")"
	[ -n "$type" ] || { json_error "Unsupported app"; return 0; }
	validate_section "$section" "$type" || return 0

	if ! command -v curl >/dev/null 2>&1; then
		json_error "curl is required for provider tests"
		return 0
	fi

	name="$(section_get "$section" name)"
	base_url="$(section_get "$section" base_url)"
	new_api_key="$(section_get "$section" api_key)"
	secret_store_if_needed "$section" "$new_api_key" || { json_error "Failed to save API key secret"; return 0; }
	uci -q commit "$CONFIG"
	api_key="$(secret_get "$section")"
	model="$(section_get "$section" model)"
	timeout="$(uci -q get "$CONFIG.proxy.upstream_timeout")"
	[ -n "$timeout" ] || timeout="60"

	require_value "$name" "Name" || return 0
	require_value "$base_url" "Base URL" || return 0
	require_value "$api_key" "API Key" || return 0
	require_value "$model" "Model" || return 0
	valid_url "$base_url" || { json_error "Base URL must start with http:// or https://"; return 0; }

	headers="/tmp/ccswitch-test.$$.headers"
	body="/tmp/ccswitch-test.$$.body"
	request="/tmp/ccswitch-test.$$.json"

	case "$app" in
		claude)
			api_key_field="$(section_get "$section" api_key_field)"
			api_format="$(section_get "$section" api_format)"
			is_full_url="$(section_get "$section" is_full_url)"
			[ -n "$api_key_field" ] || api_key_field="ANTHROPIC_AUTH_TOKEN"
			[ -n "$api_format" ] || api_format="anthropic"
			[ "$api_format" = "anthropic" ] || { json_error "Claude provider test currently supports Anthropic-compatible endpoints"; return 0; }
			path="/v1/messages"
			url="$(join_url "$base_url" "$path" "$is_full_url")"
			printf '{"model":"%s","max_tokens":1,"messages":[{"role":"user","content":"ping"}],"stream":false}\n' "$(json_escape "$model")" > "$request"
			if [ "$api_key_field" = "ANTHROPIC_API_KEY" ]; then
				curl -sS --connect-timeout 15 --max-time "$timeout" -D "$headers" -o "$body" \
					-H "Content-Type: application/json" \
					-H "x-api-key: $api_key" \
					-H "anthropic-version: 2023-06-01" \
					--data-binary "@$request" "$url" >/dev/null 2>&1
			else
				curl -sS --connect-timeout 15 --max-time "$timeout" -D "$headers" -o "$body" \
					-H "Content-Type: application/json" \
					-H "Authorization: Bearer $api_key" \
					-H "anthropic-version: 2023-06-01" \
					--data-binary "@$request" "$url" >/dev/null 2>&1
			fi
			rc="$?"
		;;
		codex)
			wire_api="$(section_get "$section" wire_api)"
			[ -n "$wire_api" ] || wire_api="responses"
			base_url="$(normalize_codex_base_url "$base_url")"
			if [ "$wire_api" = "chat" ]; then
				path="/chat/completions"
				printf '{"model":"%s","messages":[{"role":"user","content":"ping"}],"max_tokens":1,"stream":false}\n' "$(json_escape "$model")" > "$request"
			else
				path="/responses"
				printf '{"model":"%s","input":"ping","max_output_tokens":1,"stream":false}\n' "$(json_escape "$model")" > "$request"
			fi
			url="$(join_url "$base_url" "$path" "0")"
			curl -sS --connect-timeout 15 --max-time "$timeout" -D "$headers" -o "$body" \
				-H "Content-Type: application/json" \
				-H "Authorization: Bearer $api_key" \
				--data-binary "@$request" "$url" >/dev/null 2>&1
			rc="$?"
		;;
	esac

	if [ "$rc" != "0" ]; then
		printf '{"error":"curl failed","type":"network_error"}' > "$body"
		status=502
	else
		status="$(extract_status "$headers")"
	fi
	[ -n "$status" ] || status=502
	kind="$(diagnosis_type "$status" "$body")"
	hint="$(diagnosis_hint "$kind")"

	printf '{"ok":true,"success":%s,"status":%s,"diagnosis_type":"%s","hint":"%s","provider":"%s","model":"%s","url":"%s","body":"%s"}\n' \
		"$(case "$status" in 2*|3*) printf true ;; *) printf false ;; esac)" \
		"$status" \
		"$(json_escape "$kind")" \
		"$(json_escape "$hint")" \
		"$(json_escape "$name")" \
		"$(json_escape "$model")" \
		"$(json_escape "$url")" \
		"$(json_file_excerpt "$body" 1200)"

	rm -f "$headers" "$body" "$request"
}

list_backups_json() {
	local app="$1" dir item first path
	dir="$(backup_dir)/$app"
	first=1
	printf '['
	if [ -d "$dir" ]; then
		for item in $(ls -1t "$dir" 2>/dev/null | head -n 20); do
			path="$dir/$item"
			[ "$first" = "1" ] || printf ','
			first=0
			printf '"%s"' "$(json_escape "$path")"
		done
	fi
	printf ']'
}

status_app() {
	local app="$1" current current_name claude_dir codex_dir backup exists1 exists2 route_mode
	backup="$(backup_dir)"

	case "$app" in
		claude)
			current="$(global_get current_claude "")"
			current_name="$(section_get "$current" name)"
			route_mode="$(global_get claude_route_mode direct)"
			claude_dir="$(global_get claude_config_dir "$DEFAULT_CLAUDE_DIR")"
			[ -f "$claude_dir/settings.json" ] && exists1=1 || exists1=0
			printf '{"ok":true,"app":"claude","current":"%s","current_name":"%s","route_mode":"%s","has_key":%s,"paths":["%s"],"exists":[%s],"backup_dir":"%s","backups":' \
				"$(json_escape "$current")" \
				"$(json_escape "$current_name")" \
				"$(json_escape "$route_mode")" \
				"$(has_secret "$current" && printf true || printf false)" \
				"$(json_escape "$claude_dir/settings.json")" \
				"$(json_bool "$exists1")" \
				"$(json_escape "$backup/claude")"
			list_backups_json claude
			printf '}\n'
		;;
		codex)
			current="$(global_get current_codex "")"
			current_name="$(section_get "$current" name)"
			route_mode="$(global_get codex_route_mode direct)"
			codex_dir="$(global_get codex_config_dir "$DEFAULT_CODEX_DIR")"
			[ -f "$codex_dir/auth.json" ] && exists1=1 || exists1=0
			[ -f "$codex_dir/config.toml" ] && exists2=1 || exists2=0
			printf '{"ok":true,"app":"codex","current":"%s","current_name":"%s","route_mode":"%s","has_key":%s,"paths":["%s","%s"],"exists":[%s,%s],"backup_dir":"%s","backups":' \
				"$(json_escape "$current")" \
				"$(json_escape "$current_name")" \
				"$(json_escape "$route_mode")" \
				"$(has_secret "$current" && printf true || printf false)" \
				"$(json_escape "$codex_dir/auth.json")" \
				"$(json_escape "$codex_dir/config.toml")" \
				"$(json_bool "$exists1")" \
				"$(json_bool "$exists2")" \
				"$(json_escape "$backup/codex")"
			list_backups_json codex
			printf '}\n'
		;;
		*) json_error "Unsupported app" ;;
	esac
}

restore_latest_claude() {
	local dir target latest
	dir="$(backup_dir)/claude"
	target="$(global_get claude_config_dir "$DEFAULT_CLAUDE_DIR")/settings.json"
	latest="$(ls -1t "$dir"/settings.json.* 2>/dev/null | head -n 1)"
	[ -n "$latest" ] || { json_error "No Claude backup found"; return 0; }
	backup_file claude "$target" >/dev/null 2>&1
	mkdir -p "$(dirname "$target")" || { json_error "Failed to create Claude config directory"; return 0; }
	cp "$latest" "$target" && chmod 600 "$target" 2>/dev/null || { json_error "Failed to restore Claude backup"; return 0; }
	logger -t ccswitch "Claude backup restored from $latest"
	json_ok "Claude backup restored"
}

restore_latest_codex() {
	local dir codex_dir latest base stamp auth_backup config_backup
	dir="$(backup_dir)/codex"
	codex_dir="$(global_get codex_config_dir "$DEFAULT_CODEX_DIR")"
	latest="$(ls -1t "$dir"/config.toml.* "$dir"/auth.json.* 2>/dev/null | head -n 1)"
	[ -n "$latest" ] || { json_error "No Codex backup found"; return 0; }

	base="$(basename "$latest")"
	case "$base" in
		config.toml.*) stamp="${base#config.toml.}" ;;
		auth.json.*) stamp="${base#auth.json.}" ;;
		*) stamp="" ;;
	esac
	[ -n "$stamp" ] || { json_error "Invalid Codex backup name"; return 0; }

	auth_backup="$dir/auth.json.$stamp"
	config_backup="$dir/config.toml.$stamp"
	mkdir -p "$codex_dir" || { json_error "Failed to create Codex config directory"; return 0; }
	backup_file codex "$codex_dir/auth.json" >/dev/null 2>&1
	backup_file codex "$codex_dir/config.toml" >/dev/null 2>&1
	[ -f "$auth_backup" ] && cp "$auth_backup" "$codex_dir/auth.json"
	[ -f "$config_backup" ] && cp "$config_backup" "$codex_dir/config.toml"
	chmod 600 "$codex_dir/auth.json" "$codex_dir/config.toml" 2>/dev/null
	logger -t ccswitch "Codex backup restored from stamp $stamp"
	json_ok "Codex backup restored"
}

restore_app() {
	case "$1" in
		claude) restore_latest_claude ;;
		codex) restore_latest_codex ;;
		*) json_error "Unsupported app" ;;
	esac
}

usage_count_matching() {
	local pattern="$1" count
	[ -f "$USAGE_LOG" ] || { printf 0; return; }
	count="$(grep -c "$pattern" "$USAGE_LOG" 2>/dev/null)"
	[ -n "$count" ] || count=0
	printf '%s' "$count"
}

proxy_logs_json() {
	local first=1 line
	printf '['
	if command -v logread >/dev/null 2>&1; then
		logread -e ccswitch-proxy 2>/dev/null | tail -n 30 | while IFS= read -r line; do
			[ "$first" = "1" ] || printf ','
			first=0
			printf '"%s"' "$(json_escape "$line")"
		done
	fi
	printf ']'
}

proxy_status() {
	local enabled address port timeout usage_retain running client count errors log_file
	enabled="$(uci -q get "$CONFIG.proxy.enabled")"
	address="$(uci -q get "$CONFIG.proxy.listen_address")"
	port="$(uci -q get "$CONFIG.proxy.listen_port")"
	timeout="$(uci -q get "$CONFIG.proxy.upstream_timeout")"
	usage_retain="$(uci -q get "$CONFIG.proxy.usage_retain")"
	log_file="$USAGE_LOG"
	[ -n "$enabled" ] || enabled=0
	[ -n "$address" ] || address="127.0.0.1"
	[ -n "$port" ] || port="15721"
	[ -n "$timeout" ] || timeout="600"
	[ -n "$usage_retain" ] || usage_retain="$DEFAULT_USAGE_RETAIN"
	[ -f "$USAGE_LOG" ] && count="$(wc -l < "$USAGE_LOG" 2>/dev/null | tr -d ' ')" || count=0
	errors="$(usage_count_matching '"status":[45]')"

	if /etc/init.d/ccswitch-proxy running >/dev/null 2>&1; then running=1; else running=0; fi
	if command -v curl >/dev/null 2>&1; then client="curl"; else client=""; fi

	printf '{"ok":true,"enabled":%s,"running":%s,"listen_address":"%s","listen_port":"%s","listen":"%s:%s","upstream_timeout":"%s","usage_retain":"%s","http_client":"%s","log_file":"%s","log_count":%s,"error_count":%s,"logs":' \
		"$(json_bool "$enabled")" \
		"$(json_bool "$running")" \
		"$(json_escape "$address")" \
		"$(json_escape "$port")" \
		"$(json_escape "$address")" \
		"$(json_escape "$port")" \
		"$(json_escape "$timeout")" \
		"$(json_escape "$usage_retain")" \
		"$(json_escape "$client")" \
		"$(json_escape "$log_file")" \
		"$count" \
		"$errors"
	proxy_logs_json
	printf '}\n'
}

proxy_restart() {
	proxy_control restart
}

proxy_control() {
	local action="$1"
	if [ -x /etc/init.d/ccswitch-proxy ]; then
		case "$action" in
			start)
				uci -q set "$CONFIG.proxy.enabled=1"
				uci -q commit "$CONFIG"
				/etc/init.d/ccswitch-proxy enable >/dev/null 2>&1
				/etc/init.d/ccswitch-proxy start >/dev/null 2>&1
			;;
			stop)
				uci -q set "$CONFIG.proxy.enabled=0"
				uci -q commit "$CONFIG"
				/etc/init.d/ccswitch-proxy stop >/dev/null 2>&1
			;;
			restart|'')
				uci -q set "$CONFIG.proxy.enabled=1"
				uci -q commit "$CONFIG"
				/etc/init.d/ccswitch-proxy enable >/dev/null 2>&1
				/etc/init.d/ccswitch-proxy restart >/dev/null 2>&1
			;;
			enable)
				uci -q set "$CONFIG.proxy.enabled=1"
				uci -q commit "$CONFIG"
				/etc/init.d/ccswitch-proxy enable >/dev/null 2>&1
			;;
			disable)
				uci -q set "$CONFIG.proxy.enabled=0"
				uci -q commit "$CONFIG"
				/etc/init.d/ccswitch-proxy disable >/dev/null 2>&1
				/etc/init.d/ccswitch-proxy stop >/dev/null 2>&1
			;;
			*) json_error "Unsupported proxy action"; return 0 ;;
		esac
		proxy_status
	else
		json_error "ccswitch-proxy service is not installed"
	fi
}

usage_entries_json() {
	local limit="$1" errors_only="$2" first line
	[ -n "$limit" ] || limit=100
	[ "$limit" -gt 0 ] 2>/dev/null || limit=100
	first=1
	printf '['
	if [ -f "$USAGE_LOG" ]; then
		if [ "$errors_only" = "1" ]; then
			grep '"status":[45]' "$USAGE_LOG" 2>/dev/null | tail -n "$limit" | while IFS= read -r line; do
				case "$line" in
					\{*\})
						[ "$first" = "1" ] || printf ','
						first=0
						printf '%s' "$line"
					;;
				esac
			done
		else
			tail -n "$limit" "$USAGE_LOG" 2>/dev/null | while IFS= read -r line; do
				case "$line" in
					\{*\})
						[ "$first" = "1" ] || printf ','
						first=0
						printf '%s' "$line"
					;;
				esac
			done
		fi
	fi
	printf ']'
}

usage_summary_json() {
	local today
	today="$(date '+%Y-%m-%d')"
	if [ ! -f "$USAGE_LOG" ]; then
		printf '{"total_requests":0,"error_requests":0,"input_tokens":0,"output_tokens":0,"cache_tokens":0,"total_tokens":0,"estimated_cost":0,"today_requests":0,"today_errors":0,"today_input_tokens":0,"today_output_tokens":0,"today_cache_tokens":0,"today_total_tokens":0,"today_estimated_cost":0,"by_model":[],"by_provider":[],"by_error":[]}'
		return 0
	fi

	awk -v today="$today" '
	function esc(s) {
		gsub(/\\/,"\\\\",s)
		gsub(/"/,"\\\"",s)
		return s
	}
	function str(key, line, val) {
		val = line
		sub(".*\"" key "\":\"", "", val)
		if (val == line) return ""
		sub("\".*", "", val)
		gsub(/\\\"/, "\"", val)
		gsub(/\\\\/, "\\", val)
		return val
	}
	function num(key, line, val) {
		val = line
		sub(".*\"" key "\":", "", val)
		if (val == line) return 0
		sub("[,}].*", "", val)
		return val + 0
	}
	function item_array(kind,    first,k,name) {
		first = 1
		printf "["
		for (k in counts) {
			if (substr(k, 1, length(kind) + 1) != kind SUBSEP) continue
			name = substr(k, length(kind) + 2)
			if (!first) printf ","
			first = 0
			printf "{\"name\":\"%s\",\"requests\":%d,\"errors\":%d,\"input_tokens\":%.0f,\"output_tokens\":%.0f,\"cache_tokens\":%.0f,\"total_tokens\":%.0f,\"estimated_cost\":%.8f}", esc(name), counts[k], errs[k], inputs[k], outputs[k], caches[k], totals[k], costs[k]
		}
		printf "]"
	}
	function add(kind, name, status, i, o, c, t, money, key) {
		if (name == "") name = "未知"
		key = kind SUBSEP name
		counts[key]++
		if (status >= 400) errs[key]++
		inputs[key] += i
		outputs[key] += o
		caches[key] += c
		totals[key] += t
		costs[key] += money
	}
	{
		time = str("time", $0)
		model = str("model", $0)
		provider = str("provider", $0)
		errtype = str("error_type", $0)
		status = num("status", $0)
		i = num("input_tokens", $0)
		o = num("output_tokens", $0)
		c = num("cache_tokens", $0)
		t = num("total_tokens", $0)
		money = num("estimated_cost", $0)

		total_requests++
		if (status >= 400) error_requests++
		all_i += i; all_o += o; all_c += c; all_t += t; all_money += money

		if (substr(time, 1, 10) == today) {
			today_requests++
			if (status >= 400) today_errors++
			today_i += i; today_o += o; today_c += c; today_t += t; today_money += money
		}

		add("model", model, status, i, o, c, t, money)
		add("provider", provider, status, i, o, c, t, money)
		if (status >= 400) add("error", errtype, status, i, o, c, t, money)
	}
	END {
		printf "{\"total_requests\":%d,\"error_requests\":%d,\"input_tokens\":%.0f,\"output_tokens\":%.0f,\"cache_tokens\":%.0f,\"total_tokens\":%.0f,\"estimated_cost\":%.8f,\"today_requests\":%d,\"today_errors\":%d,\"today_input_tokens\":%.0f,\"today_output_tokens\":%.0f,\"today_cache_tokens\":%.0f,\"today_total_tokens\":%.0f,\"today_estimated_cost\":%.8f,\"by_model\":", total_requests, error_requests, all_i, all_o, all_c, all_t, all_money, today_requests, today_errors, today_i, today_o, today_c, today_t, today_money
		item_array("model")
		printf ",\"by_provider\":"
		item_array("provider")
		printf ",\"by_error\":"
		item_array("error")
		printf "}"
	}
	' "$USAGE_LOG"
}

usage_json() {
	local limit="$1" count errors
	[ -f "$USAGE_LOG" ] && count="$(wc -l < "$USAGE_LOG" 2>/dev/null | tr -d ' ')" || count=0
	errors="$(usage_count_matching '"status":[45]')"
	printf '{"ok":true,"log_file":"%s","total":%s,"errors":%s,"summary":' "$(json_escape "$USAGE_LOG")" "$count" "$errors"
	usage_summary_json
	printf ',"entries":'
	usage_entries_json "$limit" 0
	printf ',"recent_errors":'
	usage_entries_json 30 1
	printf '}\n'
}

usage_clear() {
	mkdir -p "$(dirname "$USAGE_LOG")"
	: > "$USAGE_LOG"
	chmod 600 "$USAGE_LOG" 2>/dev/null
	json_ok "Usage log cleared"
}

usage_trim() {
	local limit="$1" tmp
	[ -n "$limit" ] || limit="$(uci -q get "$CONFIG.proxy.usage_retain")"
	[ -n "$limit" ] || limit="$DEFAULT_USAGE_RETAIN"
	[ "$limit" -gt 0 ] 2>/dev/null || limit="$DEFAULT_USAGE_RETAIN"
	[ -f "$USAGE_LOG" ] || { json_ok "Usage log trimmed"; return 0; }
	tmp="$USAGE_LOG.tmp.$$"
	tail -n "$limit" "$USAGE_LOG" > "$tmp" && mv "$tmp" "$USAGE_LOG"
	chmod 600 "$USAGE_LOG" 2>/dev/null
	json_ok "Usage log trimmed"
}

usage_export() {
	local limit="$1" first line
	[ -n "$limit" ] || limit=5000
	[ "$limit" -gt 0 ] 2>/dev/null || limit=5000
	printf '{"ok":true,"filename":"ccswitch-usage.jsonl","content":"'
	if [ -f "$USAGE_LOG" ]; then
		first=1
		tail -n "$limit" "$USAGE_LOG" 2>/dev/null | while IFS= read -r line; do
			[ "$first" = "1" ] || printf '\\n'
			first=0
			printf '%s' "$(json_escape "$line")"
		done
	fi
	printf '"}\n'
}

case "$1" in
	list)
		printf '{'
		printf '"status":{"app":""},'
		printf '"backups":{"app":""},'
		printf '"apply":{"app":"","section":""},'
		printf '"preview":{"app":"","section":""},'
		printf '"test":{"app":"","section":""},'
		printf '"clone":{"app":"","section":""},'
		printf '"failover":{"app":"","section":""},'
		printf '"restore":{"app":"","file":""},'
		printf '"proxy_status":{},'
		printf '"proxy_restart":{},'
		printf '"proxy_control":{"action":""},'
		printf '"usage":{"limit":0},'
		printf '"usage_clear":{},'
		printf '"usage_trim":{"limit":0},'
		printf '"usage_export":{"limit":0}'
		printf '}\n'
	;;
	call)
		read -r input
		app="$(json_arg "$input" '@.app')"
		section="$(json_arg "$input" '@.section')"
		limit="$(json_arg "$input" '@.limit')"
		action="$(json_arg "$input" '@.action')"

		case "$2" in
			status|backups) status_app "$app" ;;
			apply)
				case "$app" in
					claude) apply_claude "$section" ;;
					codex) apply_codex "$section" ;;
					*) json_error "Unsupported app" ;;
				esac
			;;
			preview) preview_provider "$app" "$section" ;;
			test) test_provider "$app" "$section" ;;
			clone) clone_provider "$app" "$section" ;;
			failover) failover_provider "$app" "$section" ;;
			restore) restore_app "$app" ;;
			proxy_status) proxy_status ;;
			proxy_restart) proxy_restart ;;
			proxy_control) proxy_control "$action" ;;
			usage) usage_json "$limit" ;;
			usage_clear) usage_clear ;;
			usage_trim) usage_trim "$limit" ;;
			usage_export) usage_export "$limit" ;;
			*) json_error "Unsupported method" ;;
		esac
	;;
esac
