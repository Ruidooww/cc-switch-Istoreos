config global 'global'
	option claude_config_dir '/root/.claude'
	option codex_config_dir '/root/.codex'
	option backup_dir '/etc/ccswitch/backups'
	option backup_retain '10'
	option current_claude ''
	option current_codex ''

config proxy 'proxy'
	option enabled '0'
	option listen_address '127.0.0.1'
	option listen_port '15721'
	option log_requests '1'
	option upstream_timeout '600'

config claude_provider
	option name 'Anthropic Compatible'
	option preset 'anthropic'
	option enabled '0'
	option website_url 'https://console.anthropic.com'
	option base_url 'https://api.anthropic.com'
	option is_full_url '0'
	option api_key ''
	option api_format 'anthropic'
	option api_key_field 'ANTHROPIC_AUTH_TOKEN'
	option model 'claude-sonnet-4-5'
	option haiku_model 'claude-haiku-4-5'
	option sonnet_model 'claude-sonnet-4-5'
	option opus_model 'claude-opus-4-1'
	option hide_ai_signature '0'
	option teammates_mode '0'
	option enable_tool_search '0'
	option max_thinking_enabled '0'
	option disable_auto_update '0'
	option notes 'Fill API key, enable this provider, then click Enable.'

config claude_provider
	option name 'DeepSeek Anthropic'
	option preset 'deepseek_anthropic'
	option enabled '0'
	option website_url 'https://platform.deepseek.com'
	option base_url 'https://api.deepseek.com/anthropic'
	option is_full_url '0'
	option api_key ''
	option api_format 'anthropic'
	option api_key_field 'ANTHROPIC_AUTH_TOKEN'
	option model 'deepseek-v4-pro'
	option haiku_model 'deepseek-v4-pro'
	option sonnet_model 'deepseek-v4-pro'
	option opus_model 'deepseek-v4-pro'
	option hide_ai_signature '0'
	option teammates_mode '0'
	option enable_tool_search '0'
	option max_thinking_enabled '0'
	option disable_auto_update '0'
	option notes 'DeepSeek Anthropic-compatible endpoint example.'

config codex_provider
	option name 'OpenAI Compatible'
	option preset 'openai'
	option enabled '0'
	option base_url 'https://api.openai.com/v1'
	option api_key ''
	option model 'gpt-5.1-codex'
	option wire_api 'responses'
	option notes 'Fill API key, enable this provider, then click Enable.'

config codex_provider
	option name 'NewAPI'
	option preset 'newapi'
	option enabled '0'
	option base_url 'https://example.com/v1'
	option api_key ''
	option model 'gpt-5.1-codex'
	option wire_api 'responses'
	option notes 'Replace Base URL with your NewAPI endpoint.'

